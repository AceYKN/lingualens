{
  "name": "lingualens",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:pages": "npm run build && wrangler pages dev",
    "build": "tsc -b && vite build",
    "functions:check": "wrangler pages functions build functions --outdir output/functions-build-check --compatibility-date 2026-07-17",
